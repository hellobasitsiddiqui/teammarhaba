# TeamMarhaba — required runtime environment (contract).
#
# This is the single source of truth for the env vars the backend service needs.
# It is the contract the fail-loud validator (TM-64 / 1.4.5) enforces at boot and
# that the Cloud Run deploy (deploy.yml `backend` job) injects in production.
#
# Copy to `.env` for local dev and fill in real values. NEVER commit a real `.env`
# (git-ignored). Sensitive values (marked SECRET) come from Secret Manager in
# production and must never be hard-coded here or printed to logs.

# ---- Spring ----
# Active profile. Production runs `prod`; local dev typically leaves this unset.
SPRING_PROFILES_ACTIVE=prod

# ---- Database: Cloud SQL Postgres (via the Cloud SQL Auth Proxy) ----
DB_NAME=teammarhaba
DB_USER=app
# SECRET — Secret Manager: `teammarhaba-db-app-password`. Injected by Cloud Run as
# DB_PASSWORD via --set-secrets; never committed. Leave blank here.
# Local dev (docker-compose, TM-52): set a value in your own `.env` — it seeds the
# Postgres container's password and the backend datasource. Never commit your `.env`.
DB_PASSWORD=
# Cloud SQL instance connection name; the Auth Proxy socket is /cloudsql/<this>.
INSTANCE_CONNECTION_NAME=teammarhaba:europe-west2:teammarhaba-pg

# ---- Firebase (Auth token verification) ----
# Non-sensitive: the project id. The backend verifies Firebase ID tokens against
# this project (Admin SDK uses the runtime service account's ADC — no key needed).
FIREBASE_PROJECT_ID=teammarhaba

# ---- Admin bootstrap (TM-110) ----
# OPTIONAL. Email of the first admin: on startup the backend promotes this Firebase
# account to ADMIN (custom claim), breaking the chicken-and-egg where JIT makes every
# new account a USER and the set-role endpoint needs an existing admin. The account
# must have signed in at least once so it exists in Firebase Auth. Leave blank for no
# bootstrap (dev/test never set it). Not a secret.
ADMIN_BOOTSTRAP_EMAIL=

# ---- Passwordless email-code login (TM-234) ----
# OPTIONAL tunables (NOT secrets) for the default email-code sign-in. All have safe defaults
# baked in (EmailCodeProperties) so the feature works with none of these set; override only to
# tighten. A non-positive ttl/length/limit fails startup loudly rather than weakening the flow.
# EMAIL_CODE_LENGTH=6                 # digits in the one-time code
# EMAIL_CODE_TTL=10m                  # how long an issued code stays valid
# EMAIL_CODE_SEND_COOLDOWN=60s        # min gap between code requests for one address
# EMAIL_CODE_MAX_VERIFY_ATTEMPTS=5    # wrong guesses before the code is burned
# Bounded state + per-IP limit (TM-247) — cap memory under a flood of distinct addresses / IPs:
# EMAIL_CODE_MAX_OUTSTANDING=100000   # hard cap on addresses with in-memory auth state
# EMAIL_CODE_IP_REQUEST_LIMIT=20      # max request calls per client IP per window (429 once exceeded)
# EMAIL_CODE_IP_REQUEST_WINDOW=1m     # fixed window for the per-IP limit
# EMAIL_CODE_MAX_TRACKED_IPS=100000   # hard cap on IPs the limiter tracks (bounds the limiter itself)

# ---- Email-code delivery: Google Workspace SMTP (TM-249) ----
# Wires real delivery of the 6-digit login code via Google Workspace SMTP on 10xai.co.uk.
# Leave MAIL_HOST blank to keep the logging fallback (dev/test/CI/e2e): no SMTP connection is
# attempted and codes are not emailed. Set MAIL_HOST (+ the two SECRET creds below) to turn
# delivery ON in an environment. The SMTP mailer fails startup loudly if enabled with blank creds.
#
# Human prereq (one-time, ~5 min): on a 10xai.co.uk Workspace account (ideally a no-reply@
# mailbox) enable 2-Step Verification, create an *app password*, and put it in MAIL_PASSWORD
# below (as a Cloud Run / GH secret in real envs). smtp.gmail.com + an app password is the
# simple route; smtp-relay.gmail.com is the send-as-any-alias alternative (needs Workspace admin).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# SECRET — Secret Manager. The Workspace mailbox the app password belongs to (e.g. no-reply@10xai.co.uk).
MAIL_USERNAME=
# SECRET — Secret Manager: the Google Workspace *app password* (not the account password). Never commit.
MAIL_PASSWORD=
# OPTIONAL — From address + display name on the code email. Default no-reply@10xai.co.uk / TeamMarhaba.
# APP_MAIL_FROM=no-reply@10xai.co.uk
# APP_MAIL_FROM_NAME=TeamMarhaba
# OPTIONAL — explicit on-switch (alternative to setting MAIL_HOST). Still needs a host + creds.
# MAIL_SMTP_ENABLED=false

# ---- Notes ----
# PORT is NOT listed: Cloud Run injects it and Spring binds it (server.port=${PORT:8080}).
# It is platform-provided, not an operator-supplied secret/config.
