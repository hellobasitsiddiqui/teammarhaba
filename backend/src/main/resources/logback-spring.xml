<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging config (TM-73). prod emits structured JSON (Cloud Run -> Cloud Logging) so logs are
  searchable; dev/test stay human-readable. Every line carries the MDC `traceId` set per request
  by CorrelationIdFilter, so all logs for one request share an id. Never log tokens/secrets.
-->
<configuration>

    <!-- Human-readable console for local dev/test and the default profile. -->
    <springProfile name="dev,test,default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId:-no-trace}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Structured JSON for prod via LogstashEncoder (TM-73; fix TM-140). It emits the FORMATTED
         message (SLF4J `{}` args substituted — logback's built-in JsonEncoder did NOT, so prod logs
         showed literal `{}`) and lifts MDC entries (the per-request `traceId` from CorrelationIdFilter)
         to top-level fields, so logs stay searchable + correlatable in Cloud Logging. -->
    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

</configuration>
