<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<!-- Usage-description strings (TM-350). iOS silently suppresses a permission prompt (or crashes on
	     first access) if the matching NSxxxUsageDescription is missing, so these mirror the runtime
	     permissions declared in android/app/src/main/AndroidManifest.xml. Copy is seeded from the
	     existing product strings (web/src/assets/geolocation.js RATIONALE, native-camera.js prompt
	     labels) so the on-device explanation matches what the app already tells users. -->
	<key>NSCameraUsageDescription</key>
	<string>TeamMarhaba uses your camera to take a profile photo.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>TeamMarhaba lets you choose a profile photo from your library.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TeamMarhaba uses your location to show events and content near you.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>TeamMarhaba uses Face ID to unlock the app and confirm sensitive actions.</string>
	<!-- NSPhotoLibraryAddUsageDescription is intentionally OMITTED: the avatar flow calls
	     Camera.getPhoto with resultType 'dataUrl' and never sets saveToGallery, so nothing writes to
	     the photo library. Uncomment the entry below only if saveToGallery is ever enabled:
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>TeamMarhaba saves photos you capture to your library.</string>
	-->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>TeamMarhaba</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<!-- Portrait lock (TM-667). iPhone is Portrait-only; iPad is Portrait + PortraitUpsideDown.
	     Landscape is intentionally NOT listed so the app never rotates into it — this mirrors the
	     Android userPortrait lock in AndroidManifest.xml. iPad is locked to portrait too (no
	     landscape) because the SPA has no iPad-optimized landscape layout; see TM-667 for the
	     reviewer-vetoable rationale on the iPad decision. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
