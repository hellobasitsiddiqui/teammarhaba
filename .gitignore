# Android
*.apk
*.aab
*.ap_
*.dex
local.properties
.cxx/
captures/

# Env / secrets
.env
.env.*
# but keep the committed env contract (TM-62); real .env files stay ignored
!.env.example
*.local

# Credential files — never commit (project uses keyless OIDC, so these shouldn't exist; defense-in-depth)
*-key.json
*-credentials.json
service-account*.json
application_default_credentials.json
gha-creds-*.json
*.pem
*.p12

# Android release signing — keystore + its passwords NEVER committed (TM-286/TM-245). The keystore is
# minted by a human, base64'd into the KEYSTORE_BASE64 GitHub secret, and decoded only on the CI runner.
*.jks
*.keystore
keystore.properties

# IDE
.idea/
*.iml
.vscode/

# macOS
.DS_Store

# Local Maestro e2e run artifacts (generated)
maestro-artifacts/
/0*.png
