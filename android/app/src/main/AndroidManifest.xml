<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Geolocation (TM-280): the @capacitor/geolocation plugin auto-merges these via its own
         manifest, but we declare them explicitly so a fresh checkout reads as location-aware and the
         intent is unambiguous to reviewers. COARSE is sufficient for "nearby events"; FINE is also
         declared so the plugin can request a precise fix when enableHighAccuracy is set. The runtime
         prompt is still requested in-app (web/src/assets/geolocation.js) — declaring the permission
         does not grant it. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Camera/gallery avatar capture (TM-281, @capacitor/camera). CAMERA is requested at runtime by
         the plugin when the user picks "Take a photo"; the system photo picker needs no storage perm
         on modern Android. Declared optional so the app still installs on camera-less devices. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Gallery "choose from photo" read access (TM-335). The system photo picker needs no permission,
         but on some devices/Android versions the @capacitor/camera gallery path falls back to a flow
         that requires read-media access. Declared defensively: READ_MEDIA_IMAGES is the Android 13+
         (API 33) scoped permission; READ_EXTERNAL_STORAGE covers API <= 32 (capped so it isn't
         requested on 33+ where it's a no-op). Requested at runtime by the plugin when needed. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <!-- Push notifications (TM-279). Android 13+ (API 33) gates notification posting behind a
         runtime permission the user must grant; @capacitor/push-notifications' requestPermissions()
         triggers the system prompt for it. Harmless on API < 33 (auto-granted at install). The FCM
         messaging service + receivers are merged in from the @capacitor/push-notifications library
         manifest at build time, so they aren't declared here. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Biometric app-lock + sensitive-action confirm (TM-282). USE_BIOMETRIC is the modern
         (API 28+) permission for BiometricPrompt; the plugin uses device-credential fallback so
         no separate PIN permission is needed. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
</manifest>
