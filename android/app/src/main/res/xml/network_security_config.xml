<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config (TM-231). The app talks ONLY to the hosted app over HTTPS; cleartext is
  disabled everywhere. This is the production default (cleartextTrafficPermitted="false"); there is
  deliberately no localhost/dev exception here — per the hard constraint, the shell must not change
  production/dev port config. To point at a local web server during development, override APP_URL via
  a debug build config rather than weakening this policy.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
