<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!-- Launch theme (TM-299, fixed in TM-347). On Capacitor 8 the launch splash IS the Android 12
         system splash, on EVERY API level: @capacitor/splash-screen drives it through the
         core-splashscreen compat library, and only falls back to its legacy overlay (the splash.png
         ImageView + spinner described in capacitor.config.json) when installSplashScreen() throws —
         which core-splashscreen 1.2.0 no longer does. The legacy image/spinner path is therefore dead
         code on Android, and the splash must be fully described by THESE attributes:

         - windowSplashScreenBackground: the TeamMarhaba teal, matching SplashScreen.backgroundColor
           in capacitor.config.json, so the very first frame is branded teal rather than white.
         - windowSplashScreenAnimatedIcon: a DEDICATED splash icon (@drawable/splash_icon, TM-664),
           NOT @mipmap/ic_launcher. Theme.SplashScreen defaults the centre icon to the generic Android
           placeholder (@android:drawable/sym_def_app_icon), so a branded icon must be set (TM-347).
           But pointing it at the adaptive LAUNCHER icon regressed to a plain teal box (TM-664): the
           launcher icon is a white ring on a teal background, yet the Android-12 splash discards the
           icon's own background (painting windowSplashScreenBackground — the same teal — instead) AND
           masks the icon to a tighter circle than the launcher, clipping the edge ring away. The
           dedicated splash_icon is a foreground-only white ring on transparent, padded for the splash
           safe zone, so it reads clearly as white-on-teal and is never clipped.
         - postSplashScreenTheme: the theme installSplashScreen() applies once launch completes.

         The legacy @drawable/splash bitmap stays as android:background purely for the pre-12
         starting window. Splash lifetime is timed (launchShowDuration + launchAutoHide true in
         capacitor.config.json) because the hosted SPA cannot reliably call SplashScreen.hide() —
         see TM-347. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="windowSplashScreenBackground">@color/splashBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>