<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Light theme (default). The night variant lives in values-night/themes.xml; Android picks the
         right one from the system dark-mode setting, so the native chrome follows the device theme. -->
    <style name="Theme.TeamMarhaba" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/tm_primary</item>
        <item name="colorPrimaryDark">@color/tm_primary_dark</item>
        <item name="android:colorBackground">@color/tm_background</item>
        <item name="android:statusBarColor">@color/tm_background</item>
        <item name="android:navigationBarColor">@color/tm_background</item>
        <!-- Dark icons on the light status bar (API 23+). -->
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    </style>
</resources>
