<?xml version="1.0" encoding="utf-8"?>
<!-- Circle adaptive launcher icon (TM-383): solid teal background + white ring foreground.
     <monochrome> supplies the Android 13+ themed-icon layer (the ring shape, tinted by the
     system). All layers derive from the shared source resources/icon/ (ring-white-foreground.svg
     for the raster foreground, ic_launcher_monochrome.xml for the themed layer). -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
    <monochrome android:drawable="@drawable/ic_launcher_monochrome"/>
</adaptive-icon>
