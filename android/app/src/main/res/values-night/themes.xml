<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark theme — applied automatically when the device is in dark mode. -->
    <style name="Theme.TeamMarhaba" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/tm_primary</item>
        <item name="colorPrimaryDark">@color/tm_primary_dark</item>
        <item name="android:colorBackground">@color/tm_background_dark</item>
        <item name="android:statusBarColor">@color/tm_background_dark</item>
        <item name="android:navigationBarColor">@color/tm_background_dark</item>
        <!-- Light icons on the dark status bar. -->
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>
